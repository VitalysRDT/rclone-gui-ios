    "NSFaceIDUsageDescription" : {
      "comment" : "Privacy - Face ID Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID schützt den Zugriff auf deine rclone-Konfiguration und deine gespeicherten Zugangsdaten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face ID protects access to your rclone configuration and your stored credentials."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID protege el acceso a tu configuración de rclone y a tus credenciales guardadas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face ID protège l'accès à votre configuration rclone et à vos identifiants stockés."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID protegge l'accesso alla configurazione rclone e alle credenziali salvate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID は rclone 設定と保存済み認証情報へのアクセスを保護します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID는 rclone 구성과 저장된 자격 증명에 대한 접근을 보호합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID beschermt toegang tot je rclone-configuratie en opgeslagen inloggegevens."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID chroni dostęp do konfiguracji rclone i zapisanych danych logowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "O Face ID protege o acesso à sua configuração do rclone e às credenciais armazenadas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID защищает доступ к вашей конфигурации rclone и сохраненным учетным данным."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID 用于保护对 rclone 配置和已存储凭据的访问。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Face ID 會保護 rclone 設定與已儲存憑證的存取。"
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription" : {
      "comment" : "Privacy - Local Network Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI verwendet einen internen Localhost-Server, um deine Dateien (Audio/Video), einschließlich verschlüsselter Dateien, zu streamen. Über diesen Kanal verlässt kein Datenverkehr dein Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rclone GUI uses an internal localhost server to stream your files (audio/video), including encrypted files. No traffic leaves your device through this channel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI usa un servidor localhost interno para transmitir tus archivos de audio y vídeo, incluidos archivos cifrados. Ningún tráfico sale de tu dispositivo por este canal."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rclone GUI utilise un serveur localhost interne pour streamer vos fichiers (audio/vidéo), y compris les fichiers chiffrés. Aucun trafic ne quitte votre appareil par cette voie."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI usa un server localhost interno per riprodurre in streaming i tuoi file audio/video, inclusi quelli cifrati. Nessun traffico lascia il dispositivo tramite questo canale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI は内部 localhost サーバーを使用して、暗号化ファイルを含む音声/動画ファイルをストリーミングします。この経路でデバイス外へ通信が出ることはありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI는 내부 localhost 서버를 사용해 암호화된 파일을 포함한 오디오/비디오 파일을 스트리밍합니다. 이 채널을 통해 기기 밖으로 나가는 트래픽은 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI gebruikt een interne localhost-server om je audio- en videobestanden te streamen, inclusief versleutelde bestanden. Via dit kanaal verlaat geen verkeer je apparaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI używa wewnętrznego serwera localhost do strumieniowania plików audio i wideo, także zaszyfrowanych. Ten kanał nie wysyła żadnego ruchu poza urządzenie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "O Rclone GUI usa um servidor localhost interno para transmitir seus arquivos de áudio e vídeo, incluindo arquivos criptografados. Nenhum tráfego sai do dispositivo por esse canal."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI использует внутренний сервер localhost для потоковой передачи ваших аудио- и видеофайлов, включая зашифрованные файлы. Через этот канал трафик не покидает устройство."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI 使用内部 localhost 服务器来流式传输你的音频/视频文件，包括加密文件。此通道不会让任何流量离开你的设备。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Rclone GUI 使用內部 localhost 伺服器串流你的音訊/影片檔案，包括加密檔案。此通道不會讓任何流量離開你的裝置。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Ermöglicht das Hochladen deiner Fotos und Videos auf deine rclone-Remotes."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lets you upload your photos and videos to your rclone remotes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Permite subir tus fotos y vídeos a tus remotes de rclone."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permet d'uploader vos photos et vidéos vers vos remotes rclone."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Consente di caricare foto e video sui tuoi remote rclone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "写真や動画を rclone リモートへアップロードできるようにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "사진과 비디오를 rclone 원격 저장소에 업로드할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Hiermee kun je je foto's en video's uploaden naar je rclone-remotes."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Pozwala przesyłać zdjęcia i filmy do zdalnych lokalizacji rclone."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Permite enviar suas fotos e vídeos para seus remotes do rclone."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Позволяет загружать фото и видео в ваши удаленные хранилища rclone."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "允许你将照片和视频上传到 rclone 远程。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "允許你將照片與影片上傳到 rclone 遠端。"
          }
        }
      }
    }
  },
  "version" : "1.3"
}