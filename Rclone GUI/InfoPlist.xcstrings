    "NSFaceIDUsageDescription" : {
      "comment" : "Privacy - Face ID Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face ID protects access to your rclone configuration and your stored credentials."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face ID protège l'accès à votre configuration rclone et à vos identifiants stockés."
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription" : {
      "comment" : "Privacy - Local Network Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rclone GUI uses an internal localhost server to stream your files (audio/video), including encrypted files. No traffic leaves your device through this channel."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rclone GUI utilise un serveur localhost interne pour streamer vos fichiers (audio/vidéo), y compris les fichiers chiffrés. Aucun trafic ne quitte votre appareil par cette voie."
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lets you upload your photos and videos to your rclone remotes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permet d'uploader vos photos et vidéos vers vos remotes rclone."
          }
        }
      }
    }
