<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>remote-notification</string>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Rclone GUI utilise un serveur localhost interne pour streamer vos fichiers (audio/vidéo), y compris les fichiers chiffrés. Aucun trafic ne quitte votre appareil par cette voie.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Face ID protège l'accès à votre configuration rclone et à vos identifiants stockés.</string>
	<key>NSCameraUsageDescription</key>
	<string>Pour scanner un QR code lors d'un Handoff P2P. Aucune image n'est capturée ni stockée — le flux vidéo est analysé en local et jeté immédiatement.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Permet d'uploader vos photos et vidéos vers vos remotes rclone.</string>
	<key>RcloneKeychainAccessGroup</key>
	<string>$(DEVELOPMENT_TEAM).com.rougetet.rclone-gui</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.rougetet.rclone-gui.transfer-resume</string>
		<string>com.rougetet.rclone-gui.refresh</string>
		<string>com.rougetet.rclone-gui.photo-sync</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Sauvegarde chiffrée Rclone GUI</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.rougetet.rclone-gui.rclonebackup</string>
			</array>
		</dict>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.rougetet.rclone-gui.rclonebackup</string>
			<key>UTTypeDescription</key>
			<string>Sauvegarde chiffrée Rclone GUI</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>rclonebackup</string>
				</array>
			</dict>
		</dict>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>
</dict>
</plist>
