    "iOS ne donne accès qu’à la sélection actuelle. Les autres photos ne peuvent pas être indexées ni synchronisées." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS gewährt nur Zugriff auf die aktuelle Auswahl. Andere Fotos können nicht indiziert oder synchronisiert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS only grants access to the current selection. Other photos can’t be indexed or synced."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS solo concede acceso a la selección actual. Las demás fotos no se pueden indexar ni sincronizar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS ne donne accès qu’à la sélection actuelle. Les autres photos ne peuvent pas être indexées ni synchronisées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS concede l'accesso solo alla selezione attuale. Le altre foto non possono essere indicizzate né sincronizzate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS は現在の選択にのみアクセスを許可します。他の写真はインデックス化も同期もできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS는 현재 선택 항목에만 접근을 허용합니다. 다른 사진은 인덱싱하거나 동기화할 수 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS verleent alleen toegang tot de huidige selectie. Andere foto's kunnen niet worden geïndexeerd of gesynchroniseerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS przyznaje dostęp tylko do bieżącego wyboru. Innych zdjęć nie można indeksować ani synchronizować."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O iOS concede acesso apenas à seleção atual. Outras fotos não podem ser indexadas nem sincronizadas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS предоставляет доступ только к текущей выборке. Другие фото нельзя проиндексировать или синхронизировать."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 仅授予对当前所选项目的访问权限。其他照片无法索引或同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 僅授予對當前所選專案的訪問許可權。其他照片無法索引或同步。"
          }
        }
      }
    },
