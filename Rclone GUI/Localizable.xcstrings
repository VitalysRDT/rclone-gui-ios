    "Tous tes remotes — y compris chiffrés — accessibles depuis Fichiers, en streaming et hors-ligne.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All your remotes — including encrypted ones — accessible from Files, streaming and offline."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous tes remotes — y compris chiffrés — accessibles depuis Fichiers, en streaming et hors-ligne."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos tus remotos, incluidos los cifrados, accesibles desde Archivos, en streaming y sin conexión."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i tuoi remoti, inclusi quelli cifrati, accessibili da File, in streaming e offline."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle deine Remotes — auch die verschlüsselten — zugänglich über „Dateien“, Streaming und offline."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os seus remotos — inclusive os criptografados — acessíveis em Arquivos, por streaming e off-line."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Al je remotes — ook de versleutelde — toegankelijk vanuit Bestanden, via streaming en offline."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
