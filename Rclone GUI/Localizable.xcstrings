    "Le pipeline reprend automatiquement dès que la condition est levée — vous n'avez rien à faire." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Pipeline wird automatisch fortgesetzt, sobald die Bedingung entfällt — du musst nichts tun."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The pipeline resumes automatically as soon as the condition clears — you don’t have to do anything."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La canalización se reanuda automáticamente en cuanto desaparece la condición: no tienes que hacer nada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le pipeline reprend automatiquement dès que la condition est levée — vous n'avez rien à faire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pipeline riprende automaticamente non appena la condizione si risolve: non devi fare nulla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "条件が解消されるとパイプラインは自動的に再開されます — 何もする必要はありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "조건이 해소되는 즉시 파이프라인이 자동으로 재개됩니다 — 아무것도 할 필요가 없습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De pijplijn wordt automatisch hervat zodra de voorwaarde wegvalt — je hoeft niets te doen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Potok wznawia się automatycznie, gdy tylko warunek ustąpi — nic nie musisz robić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O pipeline é retomado automaticamente assim que a condição se resolve — você não precisa fazer nada."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Конвейер автоматически возобновится, как только условие будет снято — ничего делать не нужно."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "条件一旦解除，管道会自动恢复 —— 您无需执行任何操作。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "條件一旦解除，管道會自動恢復 —— 您無需執行任何操作。"
          }
        }
      }
    },
