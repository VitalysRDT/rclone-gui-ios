          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Primeiro dê um nome ao seu remoto para mostrar a lista de conexões disponíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сначала задайте remote имя, чтобы показать список доступных подключений."
          }
        },
        "zh-Hans": {
