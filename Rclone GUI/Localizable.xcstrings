    "⚠️ En plus du token, Linkbox demande email + password (remplis-les dans le formulaire principal).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Zusätzlich zum Token benötigt Linkbox E-Mail + Passwort (trage sie im Hauptformular ein)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ In addition to the token, Linkbox requires email + password (fill them in the main form)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ En plus du token, Linkbox demande email + password (remplis-les dans le formulaire principal)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Oprócz tokena Linkbox wymaga e-maila + hasła (wpisz je w głównym formularzu)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Além do token, o Linkbox exige e-mail + senha (preencha-os no formulário principal)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Помимо токена, Linkbox требует e-mail + пароль (заполните их в основной форме)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Además del token, Linkbox requiere correo + contraseña (complétalos en el formulario principal)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Oltre al token, Linkbox richiede email + password (compilale nel modulo principale)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Naast het token vereist Linkbox e-mail + wachtwoord (vul ze in het hoofdformulier in)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ トークンに加えて、Linkbox にはメール + パスワードが必要です（メインフォームに入力してください）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ 토큰 외에 Linkbox는 이메일 + 비밀번호가 필요합니다(기본 양식에 입력하세요)."
          }
        }
      }
    },
    "⚠️ Token valide 60 minutes seulement. Pour un usage durable, créer une vraie app + JWT (voir docs rclone box).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Token nur 60 Minuten gültig. Für dauerhafte Nutzung erstelle eine echte App + JWT (siehe die rclone-box-Doku)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Token valid for 60 minutes only. For lasting use, create a real app + JWT (see the rclone box docs)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Token valide 60 minutes seulement. Pour un usage durable, créer une vraie app + JWT (voir docs rclone box)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Token valido solo per 60 minuti. Per un uso duraturo, crea una vera app + JWT (vedi la documentazione di rclone box)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ El token solo es válido durante 60 minutos. Para un uso duradero, crea una app real + JWT (consulta la documentación de rclone box)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Token válido por apenas 60 minutos. Para uso duradouro, crie um app real + JWT (consulte a documentação do rclone box)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Token slechts 60 minuten geldig. Maak voor langdurig gebruik een echte app + JWT aan (zie de rclone-box-documentatie)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Токен действителен только 60 минут. Для длительного использования создайте полноценное приложение + JWT (см. документацию rclone по box)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ Token ważny tylko przez 60 minut. Do trwałego użytku utwórz prawdziwą aplikację + JWT (zobacz dokumentację rclone dotyczącą box)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⚠️ トークンの有効期限は 60 分のみです。継続して使用するには、実際のアプリ + JWT を作成してください（rclone の box ドキュメントを参照）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
