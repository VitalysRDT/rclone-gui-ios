    "« %@ » sera replacé dans %@:%@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“%1$@” will be moved to %2$@:%3$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %1$@ » sera replacé dans %2$@:%3$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%1$@» se moverá a %2$@:%3$@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«%1$@» verrà spostato in %2$@:%3$@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%1$@“ wird nach %2$@:%3$@ verschoben."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "“%1$@” será movido para %2$@:%3$@."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "“%1$@” wordt verplaatst naar %2$@:%3$@."
          }
        },
