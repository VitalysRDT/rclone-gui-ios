    "Aucun stockage disponible. Ajoute d'abord un remote (Drive, S3, SFTP…) puis reviens créer le coffre.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Speicher verfügbar. Füge zuerst ein Remote hinzu (Drive, S3, SFTP…) und komm dann zurück, um den Tresor zu erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No storage available. Add a remote first (Drive, S3, SFTP…), then come back to create the vault."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay almacenamiento disponible. Añade primero un remoto (Drive, S3, SFTP…) y vuelve para crear la bóveda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuno spazio di archiviazione disponibile. Aggiungi prima un remoto (Drive, S3, SFTP…), poi torna a creare la cassaforte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "利用できるストレージがないよ。まず remote（Drive、S3、SFTP…）を追加してから、戻って保管庫を作成してね。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "사용할 수 있는 스토리지가 없어. 먼저 remote(Drive, S3, SFTP…)를 추가한 다음, 돌아와서 금고를 만들어."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Geen opslag beschikbaar. Voeg eerst een remote toe (Drive, S3, SFTP…) en kom dan terug om de kluis aan te maken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Brak dostępnej pamięci. Najpierw dodaj remote (Drive, S3, SFTP…), a potem wróć, aby utworzyć sejf."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Nenhum armazenamento disponível. Adicione primeiro um remote (Drive, S3, SFTP…) e depois volte para criar o cofre."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
