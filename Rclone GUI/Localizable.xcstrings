    "« %@ » existe déjà à cet emplacement.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” already exists at this location."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » existe déjà à cet emplacement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» ya existe en esta ubicación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» esiste già in questa posizione."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ existiert an diesem Ort bereits."
          }
        }
      }
    },
    "« %@ » sera replacé dans %@:%@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“%1$@” will be moved to %2$@:%3$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %1$@ » sera replacé dans %2$@:%3$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%1$@» se moverá a %2$@:%3$@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«%1$@» verrà spostato in %2$@:%3$@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%1$@“ wird nach %2$@:%3$@ verschoben."
          }
        }
      }
    },
    "« %@ » sera supprimé du remote sans possibilité de restauration.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” will be deleted from the remote with no way to restore it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » sera supprimé du remote sans possibilité de restauration."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» se eliminará del remoto sin posibilidad de recuperación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» verrà eliminato dal remoto senza possibilità di ripristino."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ wird ohne Wiederherstellungsmöglichkeit vom Remote gelöscht."
          }
        }
      }
    },
