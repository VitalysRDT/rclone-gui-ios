    "Mettre en pause stoppe immédiatement le débit sans annuler les jobs.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausing immediately stops throughput without cancelling jobs."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettre en pause stoppe immédiatement le débit sans annuler les jobs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausar detiene de inmediato el rendimiento sin cancelar los trabajos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La pausa interrompe immediatamente la velocità senza annullare i processi."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Pausieren stoppt den Durchsatz sofort, ohne Aufgaben abzubrechen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausar interrompe imediatamente a taxa de transferência sem cancelar os trabalhos."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pauzeren stopt de doorvoer onmiddellijk zonder taken te annuleren."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пауза немедленно останавливает скорость без отмены заданий."
          }
        }
      }
    },
