    "« %@ » sera supprimé du remote sans possibilité de restauration.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” will be deleted from the remote with no way to restore it."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » sera supprimé du remote sans possibilité de restauration."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» se eliminará del remoto sin posibilidad de recuperación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» verrà eliminato dal remoto senza possibilità di ripristino."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ wird ohne Wiederherstellungsmöglichkeit vom Remote gelöscht."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” será excluído do remoto sem possibilidade de restauração."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” wordt van de remote verwijderd zonder mogelijkheid tot herstel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» будет удалён с remote без возможности восстановления."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@” zostanie usunięty z remote bez możliwości przywrócenia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」は復元できない形でリモートから削除されます。"
