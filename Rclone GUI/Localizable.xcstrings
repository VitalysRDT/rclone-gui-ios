    "Efface l'ancre d'essai (Keychain + iCloud) pour rejouer les 7 jours. Absent du build App Store.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht den Testanker (Keychain + iCloud), um die 7 Tage erneut zu starten. Von App-Store-Builds ausgeschlossen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clears the trial anchor (Keychain + iCloud) to replay the 7 days. Excluded from App Store builds."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czyści kotwicę okresu próbnego (Keychain + iCloud), aby ponownie odtworzyć 7 dni. Wykluczone z kompilacji App Store."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Borra el ancla de la prueba (Keychain + iCloud) para repetir los 7 días. Excluido de las compilaciones de la App Store."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancella l'ancora della prova (Keychain + iCloud) per ripetere i 7 giorni. Escluso dalle build dell'App Store."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpa a âncora do teste (Keychain + iCloud) para repetir os 7 dias. Excluído das builds da App Store."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wist het proefanker (Keychain + iCloud) om de 7 dagen opnieuw af te spelen. Uitgesloten van App Store-builds."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очищает якорь пробного периода (Keychain + iCloud) для повторного отсчёта 7 дней. Исключено из сборок App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トライアルのアンカー（Keychain + iCloud）を消去し、7 日間をやり直します。App Store ビルドからは除外されます。"
          }
        },
        "ko": {
          "stringUnit": {
