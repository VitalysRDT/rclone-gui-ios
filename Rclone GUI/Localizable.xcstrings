        }
      }
    },
    "Le fichier sera chiffré et stocké localement. Tes clés ne quittent jamais l’iPhone.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Datei wird verschlüsselt und lokal gespeichert. Deine Schlüssel verlassen niemals das iPhone."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file will be encrypted and stored locally. Your keys never leave the iPhone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo se cifrará y se almacenará localmente. Tus claves nunca salen del iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier sera chiffré et stocké localement. Tes clés ne quittent jamais l’iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il file verrà cifrato e archiviato localmente. Le tue chiavi non lasciano mai l'iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "ファイルは暗号化されてローカルに保存されるよ。鍵が iPhone の外に出ることは絶対にないよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "파일은 암호화돼 기기에 저장돼. 네 키는 절대 iPhone 밖으로 나가지 않아."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het bestand wordt versleuteld en lokaal opgeslagen. Je sleutels verlaten nooit de iPhone."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Plik zostanie zaszyfrowany i zapisany lokalnie. Twoje klucze nigdy nie opuszczają iPhone’a."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivo será criptografado e armazenado localmente. Suas chaves nunca saem do iPhone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Файл будет зашифрован и сохранён локально. Ваши ключи никогда не покидают iPhone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "文件将被加密并存储在本机。你的密钥永远不会离开 iPhone。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "檔案會被加密並儲存在本機。你的金鑰永遠不會離開 iPhone。"
          }
        }
      }
    },
