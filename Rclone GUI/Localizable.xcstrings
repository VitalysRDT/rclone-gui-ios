    "Les jobs en cours conservent leurs slots et reprendront à la reprise.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Running jobs keep their slots and will resume when you do."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les jobs en cours conservent leurs slots et reprendront à la reprise."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Lopende taken behouden hun slots en worden hervat zodra je verdergaat."
          }
        },
        "es": {
