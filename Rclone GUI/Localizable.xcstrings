    "Supprime le rclone.conf chiffré localement et la clé maître Keychain. Tu pourras ré-importer ensuite.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht die lokal verschlüsselte rclone.conf und den Keychain-Hauptschlüssel. Du kannst danach erneut importieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletes the locally encrypted rclone.conf and the Keychain master key. You can re-import afterwards."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime le rclone.conf chiffré localement et la clé maître Keychain. Tu pourras ré-importer ensuite."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "ローカルに暗号化された rclone.conf と Keychain のマスターキーを削除するよ。あとで再度読み込めるよ。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwijdert de lokaal versleutelde rclone.conf en de Keychain-hoofdsleutel. Je kunt daarna opnieuw importeren."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удаляет локально зашифрованный rclone.conf и мастер-ключ Keychain. После этого можно импортировать заново."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "刪除本機加密的 rclone.conf 以及 Keychain 主金鑰。之後你可以重新匯入。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina el rclone.conf cifrado localmente y la clave maestra del Keychain. Después puedes volver a importarlo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina il rclone.conf cifrato localmente e la chiave master del Keychain. Puoi reimportarlo in seguito."
