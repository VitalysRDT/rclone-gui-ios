    "L'abonnement se renouvelle automatiquement. Annule à tout moment dans Réglages → Identifiant Apple → Abonnements, au moins 24 h avant la fin de la période en cours.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The subscription renews automatically. Cancel any time in Settings → Apple ID → Subscriptions, at least 24 hours before the end of the current period."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'abonnement se renouvelle automatiquement. Annule à tout moment dans Réglages → Identifiant Apple → Abonnements, au moins 24 h avant la fin de la période en cours."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La suscripción se renueva automáticamente. Cancélala cuando quieras en Ajustes → Apple ID → Suscripciones, al menos 24 horas antes del final del periodo actual."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'abbonamento si rinnova automaticamente. Annullalo in qualsiasi momento in Impostazioni → Apple ID → Abbonamenti, almeno 24 ore prima della fine del periodo in corso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Abonnement verlängert sich automatisch. Kündige es jederzeit unter Einstellungen → Apple-ID → Abonnements, mindestens 24 Stunden vor Ende des aktuellen Zeitraums."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A assinatura se renova automaticamente. Cancele quando quiser em Ajustes → Apple ID → Assinaturas, pelo menos 24 horas antes do fim do período atual."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het abonnement wordt automatisch verlengd. Zeg het op elk moment op via Instellingen → Apple ID → Abonnementen, ten minste 24 uur vóór het einde van de huidige periode."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подписка продлевается автоматически. Отмените её в любой момент в «Настройки → Apple ID → Подписки» не менее чем за 24 часа до конца текущего периода."
          }
        }
      }
    },
