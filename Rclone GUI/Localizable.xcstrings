    "Donne d'abord un nom à ton remote pour afficher la liste des connexions disponibles.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib deinem Remote zuerst einen Namen, um die Liste der verfügbaren Verbindungen anzuzeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "First give your remote a name to show the list of available connections."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Primero dale un nombre a tu remoto para mostrar la lista de conexiones disponibles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Donne d'abord un nom à ton remote pour afficher la liste des connexions disponibles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assegna prima un nome al tuo remoto per mostrare l'elenco delle connessioni disponibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "まず remote に名前を付けると、利用できる接続の一覧が表示されるよ。"
