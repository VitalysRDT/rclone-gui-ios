    "Le remote « %@ » existe déjà.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Remote „%@“ existiert bereits."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The remote “%@” already exists."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El remoto «%@» ya existe."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le remote « %@ » existe déjà."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il remoto «%@» esiste già."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リモート「%@」はすでに存在します。"
          }
        },
        "nl": {
