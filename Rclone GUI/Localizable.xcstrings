    "Faites glisser pour ajuster la limite globale de bande passante en MB/s. Zéro signifie pas de limite.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag to adjust the global bandwidth limit in MB/s. Zero means no limit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser pour ajuster la limite globale de bande passante en MB/s. Zéro signifie pas de limite."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra para ajustar el límite global de ancho de banda en MB/s. Cero significa sin límite."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascina per regolare il limite globale di banda in MB/s. Zero significa nessun limite."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehe, um das globale Bandbreitenlimit in MB/s anzupassen. Null bedeutet kein Limit."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste para ajustar o limite global de banda em MB/s. Zero significa sem limite."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sleep om de algemene bandbreedtelimiet in MB/s aan te passen. Nul betekent geen limiet."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите, чтобы настроить общее ограничение пропускной способности в МБ/с. Ноль означает без ограничений."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przeciągnij, aby dostosować ogólny limit przepustowości w MB/s. Zero oznacza brak limitu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドラッグして全体の帯域幅制限を MB/s で調整します。ゼロは無制限を意味します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "드래그하여 전체 대역폭 제한을 MB/s 단위로 조정합니다. 0은 제한 없음을 의미합니다."
          }
        }
      }
    },
