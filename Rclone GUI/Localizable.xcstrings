    "« Standard » chiffre noms de fichiers et dossiers. « En clair » garde les noms lisibles (utile pour retrouver des fichiers côté fournisseur).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“Standard” encrypts file and folder names. “Plain” keeps names readable (handy to find files on the provider side)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«Standard» cifra i nomi di file e cartelle. «Plain» mantiene i nomi leggibili (utile per trovare i file sul lato provider)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「Standard」はファイル名とフォルダ名を暗号化します。「Plain」は名前を読める状態に保ちます（プロバイダ側でファイルを見つけるのに便利）。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "“Standard” criptografa os nomes de arquivos e pastas. “Plain” mantém os nomes legíveis (útil para encontrar arquivos no lado do provedor)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Standard» cifra los nombres de archivos y carpetas. «Plain» mantiene los nombres legibles (útil para encontrar archivos en el proveedor)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Standard“ verschlüsselt Datei- und Ordnernamen. „Plain“ hält die Namen lesbar (praktisch, um Dateien auf der Anbieterseite zu finden)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "“Standard” versleutelt bestands- en mapnamen. “Plain” houdt de namen leesbaar (handig om bestanden aan de providerkant te vinden)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Standard» шифрует имена файлов и папок. «Plain» оставляет имена читаемыми (удобно для поиска файлов на стороне провайдера)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„Standard” szyfruje nazwy plików i folderów. „Plain” pozostawia nazwy czytelne (przydatne do znajdowania plików po stronie dostawcy)."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "“Standard”는 파일 및 폴더 이름을 암호화합니다. “Plain”은 이름을 읽을 수 있게 유지합니다(제공자 측에서 파일을 찾는 데 유용)."
          }
        }
      }
    },
