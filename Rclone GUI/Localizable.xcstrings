    "Le pipeline reprend automatiquement dès que la condition est levée — vous n'avez rien à faire.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Pipeline wird automatisch fortgesetzt, sobald die Bedingung entfällt — du musst nichts tun."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The pipeline resumes automatically as soon as the condition clears — you don’t have to do anything."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le pipeline reprend automatiquement dès que la condition est levée — vous n'avez rien à faire."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Pipeline wznawia się automatycznie, gdy tylko warunek przestanie obowiązywać — nie musisz nic robić."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O pipeline é retomado automaticamente assim que a condição se resolve — você não precisa fazer nada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Конвейер автоматически возобновится, как только условие будет снято — ничего делать не нужно."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La canalización se reanuda automáticamente en cuanto desaparece la condición: no tienes que hacer nada."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La pipeline riprende automaticamente non appena la condizione si risolve: non devi fare nulla."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De pijplijn wordt automatisch hervat zodra de voorwaarde wegvalt — je hoeft niets te doen."
          }
        }
      }
    },
    "Le plus simple : `rclone authorize \"huaweidrive\"` sur un poste avec navigateur.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The easiest: `rclone authorize \"huaweidrive\"` on a machine with a browser."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo más fácil: `rclone authorize \"huaweidrive\"` en una máquina con navegador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le plus simple : `rclone authorize \"huaweidrive\"` sur un poste avec navigateur."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il più semplice: `rclone authorize \"huaweidrive\"` su una macchina con un browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "いちばん簡単なのは、ブラウザのあるマシンで `rclone authorize \"huaweidrive\"` を実行することだよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "가장 간단한 방법: 브라우저가 있는 컴퓨터에서 `rclone authorize \"huaweidrive\"`를 실행해."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het eenvoudigst: `rclone authorize \"huaweidrive\"` op een machine met een browser."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Najprościej: `rclone authorize \"huaweidrive\"` na komputerze z przeglądarką."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проще всего: `rclone authorize \"huaweidrive\"` на машине с браузером."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "最简单的办法：在一台带浏览器的电脑上运行 `rclone authorize \"huaweidrive\"`。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "最簡單的方法：在一台有瀏覽器的電腦上執行 `rclone authorize \"huaweidrive\"`。"
          }
        },
        "de": {
