      }
    },
    "Cette app ne réalise pas d'OAuth interactif. Tu vas obtenir un token / clé API chez %@, puis le coller ici." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Diese App führt kein interaktives OAuth durch. Du erhältst ein Token / einen API-Schlüssel bei %@ und fügst ihn dann hier ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app doesn’t perform interactive OAuth. You’ll get a token / API key from %@, then paste it here."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Esta app no realiza OAuth interactivo. Vas a obtener un token / clave de API en %@ y luego pegarlo aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette app ne réalise pas d'OAuth interactif. Tu vas obtenir un token / clé API chez %@, puis le coller ici."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Questa app non esegue l’OAuth interattivo. Otterrai un token / una chiave API su %@, poi incollalo qui."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "この app は対話型の OAuth を行わないよ。%@ で token / API キーを取得してから、ここに貼り付けてね。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "이 app은 대화형 OAuth를 하지 않아. %@에서 token / API 키를 받아서 여기에 붙여넣으면 돼."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Deze app voert geen interactieve OAuth uit. Je haalt een token / API-sleutel op bij %@ en plakt die hier."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Ta aplikacja nie korzysta z interaktywnego OAuth. Pobierzesz token / klucz API od %@, a potem wkleisz go tutaj."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Este app não faz OAuth interativo. Você vai obter um token / chave de API em %@ e depois colá-lo aqui."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Это приложение не выполняет интерактивный OAuth. Ты получишь token / ключ API у %@, а затем вставишь его сюда."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "这个 app 不会进行交互式 OAuth。你要先在 %@ 获取 token / API 密钥，再粘贴到这里。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "這個 app 不會進行互動式 OAuth。你要先在 %@ 取得 token／API 金鑰，再貼到這裡。"
          }
        }
      }
    },
    "Cette configuration est chiffrée par rclone. Saisis ton mot de passe ci-dessus puis touche « Déchiffrer et importer »." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Diese Konfiguration ist von rclone verschlüsselt. Gib dein Passwort oben ein und tippe dann auf „Entschlüsseln und importieren“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This configuration is encrypted by rclone. Enter your password above, then tap \"Decrypt and Import\"."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Esta configuración está cifrada por rclone. Introduce tu contraseña arriba y luego toca «Descifrar e importar»."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Questa configurazione è cifrata da rclone. Inserisci la tua password qui sopra, poi tocca « Decifra e importa »."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "この設定は rclone で暗号化されているよ。上にパスワードを入力してから、“復号して読み込む”をタップしてね。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "이 설정은 rclone으로 암호화돼 있어. 위에 비밀번호를 입력한 다음 “복호화 후 가져오기”를 눌러."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Deze configuratie is versleuteld door rclone. Voer hierboven je wachtwoord in en tik op “Ontsleutelen en importeren”."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Ta konfiguracja jest zaszyfrowana przez rclone. Wpisz swoje hasło powyżej, a następnie dotknij „Odszyfruj i importuj”."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Esta configuração está criptografada pelo rclone. Digite sua senha acima e toque em “Descriptografar e importar”."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Эта конфигурация зашифрована rclone. Введи свой пароль выше, затем коснись «Расшифровать и импортировать»."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "这份配置由 rclone 加密。请在上方输入你的密码，然后轻点“解密并导入”。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "這份設定是由 rclone 加密的。請在上方輸入你的密碼，然後點一下「解密並匯入」。"
          }
        }
      }
    },
    "Cette configuration rclone est chiffrée. Saisis ton mot de passe rclone pour l’importer." : {
