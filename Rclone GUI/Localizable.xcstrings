    "Pas de surprise data, batterie préservée": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Datenüberraschungen, Akku geschont"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No data surprises, battery preserved"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin sorpresas de datos, batería preservada"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データの不意の消費なし、バッテリーを節約"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터 사용 걱정 없이, 배터리 절약"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen dataverrassingen, batterij gespaard"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez niespodzianek z danymi, bateria oszczędzona"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Никаких сюрпризов с трафиком, заряд сохранён"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "不会偷跑流量，也省电"
          }
        },
