          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assegna prima un nome al tuo remoto per mostrare l'elenco delle connessioni disponibili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "利用可能な接続の一覧を表示するには、まずリモートに名前を付けてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
