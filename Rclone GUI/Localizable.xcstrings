    },
    "Les fichiers supprimés apparaîtront ici. Ils sont restaurables pendant 30 jours.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelöschte Dateien erscheinen hier. Sie können 30 Tage lang wiederhergestellt werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleted files will appear here. They can be restored for 30 days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los archivos eliminados aparecerán aquí. Se pueden restaurar durante 30 días."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les fichiers supprimés apparaîtront ici. Ils sont restaurables pendant 30 jours."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "削除されたファイルはここに表示されます。30 日間復元できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "삭제된 파일은 여기에 표시됩니다. 30일 동안 복원할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwijderde bestanden verschijnen hier. Ze kunnen 30 dagen worden hersteld."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunięte pliki pojawią się tutaj. Można je przywrócić przez 30 dni."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os arquivos excluídos aparecerão aqui. Podem ser restaurados por 30 dias."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалённые файлы появятся здесь. Их можно восстановить в течение 30 дней."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "已删除的文件会显示在这里。它们可在 30 天内恢复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "已刪除的檔案會顯示在這裡。它們可在 30 天內還原。"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I file eliminati appariranno qui. Possono essere ripristinati per 30 giorni."
          }
        }
      }
    },
    "Les jobs en cours conservent leurs slots et reprendront à la reprise.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Running jobs keep their slots and will resume when you do."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les jobs en cours conservent leurs slots et reprendront à la reprise."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lopende taken behouden hun slots en worden hervat wanneer jij dat doet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los trabajos en curso conservan sus espacios y se reanudarán cuando lo hagas tú."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I processi in corso mantengono i loro slot e riprenderanno quando lo farai tu."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Laufende Aufgaben behalten ihre Slots und werden fortgesetzt, sobald du es tust."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os trabalhos em andamento mantêm seus espaços e serão retomados quando você o fizer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выполняющиеся задания сохраняют свои слоты и возобновятся, когда возобновите вы."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Trwające zadania zachowują swoje sloty i wznowią się, gdy zrobisz to Ty."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "実行中のジョブはスロットを保持し、再開すると続行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "실행 중인 작업은 슬롯을 유지하며 재개하면 계속됩니다."
          }
        }
      }
    },
