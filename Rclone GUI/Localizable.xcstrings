    "Par défaut, les gros uploads attendent Wi-Fi + charge. iOS décide quand les tâches arrière-plan peuvent reprendre." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig warten große Uploads auf WLAN + Laden. iOS entscheidet, wann Hintergrundaufgaben fortgesetzt werden können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By default, large uploads wait for Wi-Fi + charging. iOS decides when background tasks can resume."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por defecto, las subidas grandes esperan a tener Wi-Fi + carga. iOS decide cuándo pueden reanudarse las tareas en segundo plano."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Par défaut, les gros uploads attendent Wi-Fi + charge. iOS décide quand les tâches arrière-plan peuvent reprendre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per impostazione predefinita, i caricamenti di grandi dimensioni attendono Wi-Fi + ricarica. iOS decide quando le attività in background possono riprendere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "デフォルトでは、大きなアップロードは Wi-Fi + 充電を待ちます。バックグラウンドタスクをいつ再開できるかは iOS が判断します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "기본적으로 대용량 업로드는 Wi-Fi + 충전을 기다립니다. 백그라운드 작업을 언제 재개할지는 iOS가 결정합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standaard wachten grote uploads op wifi + opladen. iOS bepaalt wanneer achtergrondtaken kunnen worden hervat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Domyślnie duże przesyłania czekają na Wi-Fi + ładowanie. iOS decyduje, kiedy zadania w tle mogą się wznowić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Por padrão, envios grandes aguardam Wi-Fi + carregamento. O iOS decide quando as tarefas em segundo plano podem ser retomadas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "По умолчанию большие выгрузки ждут Wi-Fi + зарядку. iOS решает, когда фоновые задачи могут возобновиться."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "默认情况下，大型上传会等待 Wi-Fi + 充电。iOS 决定后台任务何时可以恢复。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "預設情況下，大型上傳會等待 Wi-Fi + 充電。iOS 決定後臺任務何時可以恢復。"
          }
        }
      }
    },
