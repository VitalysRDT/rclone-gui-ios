    "Touche un remote pour ouvrir sa racine. Les favoris et récents restent locaux à cet appareil." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Tippe auf ein Remote, um dessen Stammverzeichnis zu öffnen. Favoriten und zuletzt verwendete bleiben lokal auf diesem Gerät."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap a remote to open its root. Favorites and recents stay local to this device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Toca un remote para abrir su raíz. Los favoritos y recientes permanecen locales en este dispositivo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touche un remote pour ouvrir sa racine. Les favoris et récents restent locaux à cet appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Tocca un remote per aprirne la radice. I preferiti e i recenti restano locali su questo dispositivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "remote をタップすると、そのルートが開くよ。お気に入りと最近の項目はこの端末内だけに保存されるよ。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "remote를 누르면 해당 루트가 열려. 즐겨찾기와 최근 항목은 이 기기에만 저장돼."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Tik op een remote om de hoofdmap te openen. Favorieten en recent gebruikte blijven lokaal op dit apparaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Dotknij remote, aby otworzyć jego katalog główny. Ulubione i ostatnie pozostają lokalne na tym urządzeniu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Toque em um remote para abrir sua raiz. Favoritos e recentes ficam locais neste dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Коснись remote, чтобы открыть его корень. Избранное и недавние остаются локальными на этом устройстве."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "轻点某个 remote 即可打开它的根目录。收藏和最近项目只会保留在这台设备上。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "點一下 remote 即可開啟它的根目錄。我的最愛與最近項目只會保留在這台裝置上。"
          }
        }
      }
    },
    "Touche un remote pour ouvrir sa racine. Un remote au coffre-fort se déverrouille par Face ID et reste masqué dans l'app Fichiers d'iOS tant qu'il est verrouillé." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Tap a remote to open its root. A vaulted remote unlocks with Face ID and stays hidden in the iOS Files app while locked."
