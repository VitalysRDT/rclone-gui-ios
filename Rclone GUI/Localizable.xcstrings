    "Le dossier et tout son contenu peuvent être restaurés depuis la corbeille pendant 30 jours, ou supprimés définitivement.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The folder and all its contents can be restored from the trash for 30 days, or deleted permanently."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dossier et tout son contenu peuvent être restaurés depuis la corbeille pendant 30 jours, ou supprimés définitivement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La cartella e tutto il suo contenuto possono essere ripristinati dal Cestino per 30 giorni, oppure eliminati definitivamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De map en de volledige inhoud kunnen 30 dagen uit de prullenmand worden hersteld, of permanent worden verwijderd."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "這個資料夾及其所有內容可在 30 天內從垃圾桶還原，或永久刪除。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La carpeta y todo su contenido se pueden restaurar desde la papelera durante 30 días, o eliminarse de forma permanente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Ordner und sein gesamter Inhalt können 30 Tage lang aus dem Papierkorb wiederhergestellt oder endgültig gelöscht werden."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A pasta e todo o seu conteúdo podem ser restaurados da Lixeira por 30 dias, ou excluídos permanentemente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Папку и всё её содержимое можно восстановить из корзины в течение 30 дней или удалить навсегда."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Folder i całą jego zawartość można przywrócić z kosza przez 30 dni lub usunąć trwale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォルダとそのすべての内容は、30 日間ゴミ箱から復元できるほか、完全に削除することもできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "폴더와 모든 내용은 휴지통에서 30일 동안 복원하거나 영구적으로 삭제할 수 있습니다."
          }
        }
      }
    },
    "Le fichier de destination sera écrasé sans possibilité d'annulation. La version remplacée n'est pas envoyée à la corbeille.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The destination file will be overwritten with no undo. The replaced version is not sent to the trash."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo de destino se sobrescribirá sin posibilidad de deshacer. La versión reemplazada no se envía a la papelera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier de destination sera écrasé sans possibilité d'annulation. La version remplacée n'est pas envoyée à la corbeille."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il file di destinazione verrà sovrascritto senza possibilità di annullamento. La versione sostituita non viene inviata al Cestino."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivo de destino será sobrescrito sem possibilidade de desfazer. A versão substituída não é enviada para a Lixeira."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Целевой файл будет перезаписан без возможности отмены. Заменённая версия не отправляется в корзину."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Zieldatei wird ohne Rückgängigmachen überschrieben. Die ersetzte Version wird nicht in den Papierkorb verschoben."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het doelbestand wordt overschreven zonder ongedaan maken. De vervangen versie wordt niet naar de prullenmand verplaatst."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Plik docelowy zostanie nadpisany bez możliwości cofnięcia. Zastąpiona wersja nie jest wysyłana do kosza."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "宛先ファイルは元に戻せない形で上書きされます。置き換えられたバージョンはゴミ箱に送られません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대상 파일은 실행 취소 없이 덮어쓰입니다. 교체된 버전은 휴지통으로 보내지지 않습니다."
          }
        }
      }
    },
