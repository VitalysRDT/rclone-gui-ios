        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suggerimento: per Azure, puoi anche compilare «account» + «key» direttamente nel modulo normale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ヒント: Azure の場合、通常のフォームに「account」+「key」を直接入力することもできます。"
