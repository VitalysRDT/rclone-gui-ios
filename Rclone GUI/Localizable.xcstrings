    "Sync miroir les dossiers sélectionnés : les fichiers présents uniquement dans le dossier cible peuvent être supprimés par rclone." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronisiert die ausgewählten Ordner im Spiegelmodus: Dateien, die nur im Zielordner vorhanden sind, können von rclone gelöscht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mirror-syncs the selected folders: files present only in the target folder may be deleted by rclone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincroniza en espejo las carpetas seleccionadas: rclone puede eliminar los archivos presentes solo en la carpeta de destino."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sync miroir les dossiers sélectionnés : les fichiers présents uniquement dans le dossier cible peuvent être supprimés par rclone."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincronizza in modalità mirror le cartelle selezionate: i file presenti solo nella cartella di destinazione possono essere eliminati da rclone."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選択したフォルダをミラー同期します: 宛先フォルダにのみ存在するファイルは rclone によって削除される場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "선택한 폴더를 미러 동기화합니다: 대상 폴더에만 있는 파일은 rclone에 의해 삭제될 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchroniseert de geselecteerde mappen als spiegel: bestanden die alleen in de doelmap staan, kunnen door rclone worden verwijderd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronizuje lustrzanie wybrane foldery: pliki obecne tylko w folderze docelowym mogą zostać usunięte przez rclone."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincroniza em espelho as pastas selecionadas: arquivos presentes apenas na pasta de destino podem ser excluídos pelo rclone."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Зеркально синхронизирует выбранные папки: файлы, имеющиеся только в целевой папке, могут быть удалены rclone."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对所选文件夹进行镜像同步：仅存在于目标文件夹中的文件可能会被 rclone 删除。"
