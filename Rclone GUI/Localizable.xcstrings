    "Le coffre chiffre les fichiers au-dessus de ce remote. Les données restent stockées chez le fournisseur, mais chiffrées de bout en bout.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Tresor verschlüsselt Dateien über diesem Remote. Die Daten bleiben beim Anbieter, aber Ende-zu-Ende-verschlüsselt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The vault encrypts files on top of this remote. Data stays with the provider, but end-to-end encrypted."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La cassaforte cifra i file sopra questo remoto. I dati restano presso il provider, ma cifrati end-to-end."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "保管庫はこの remote の上でファイルを暗号化するよ。データはプロバイダ側に保存されたままだけど、エンドツーエンドで暗号化されるよ。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Sejf szyfruje pliki na tym remote. Dane pozostają przechowywane u dostawcy, ale są szyfrowane end-to-end."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "保险库会在这个 remote 之上对文件进行加密。数据仍然存储在服务商那里，但采用端到端加密。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La bóveda cifra los archivos sobre este remoto. Los datos permanecen en el proveedor, pero cifrados de extremo a extremo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O cofre criptografa arquivos sobre este remoto. Os dados permanecem com o provedor, mas criptografados de ponta a ponta."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De kluis versleutelt bestanden boven op deze remote. De gegevens blijven bij de provider, maar end-to-end versleuteld."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сейф шифрует файлы поверх этого remote. Данные остаются у провайдера, но со сквозным шифрованием."
          }
        }
      }
    },
