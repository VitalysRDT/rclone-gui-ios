    "Seules les photos de ces albums seront sauvegardées.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only photos from these albums will be backed up."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les photos de ces albums seront sauvegardées."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er wordt alleen een back-up gemaakt van foto's uit deze albums."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se respaldarán las fotos de estos álbumes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verrà eseguito il backup solo delle foto di questi album."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Fotos aus diesen Alben werden gesichert."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas as fotos destes álbuns receberão backup."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Резервируются только фото из этих альбомов."
          }
        }
      }
    },
    "Seules les photos prises entre ces deux dates seront indexées par la prochaine synchronisation.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only photos taken between these two dates will be indexed by the next sync."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo las fotos tomadas entre estas dos fechas se indexarán en la próxima sincronización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les photos prises entre ces deux dates seront indexées par la prochaine synchronisation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo le foto scattate tra queste due date verranno indicizzate dalla prossima sincronizzazione."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Fotos, die zwischen diesen beiden Daten aufgenommen wurden, werden von der nächsten Synchronisierung indiziert."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas as fotos tiradas entre essas duas datas serão indexadas pela próxima sincronização."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen foto's die tussen deze twee datums zijn gemaakt, worden door de volgende synchronisatie geïndexeerd."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Следующей синхронизацией будут проиндексированы только фото, снятые между этими двумя датами."
          }
        }
      }
    },
