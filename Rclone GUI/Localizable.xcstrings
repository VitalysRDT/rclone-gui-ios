    "Format : 4 groupes de 4 lettres séparés par des tirets. Le champ « apple_id » est rempli dans le formulaire principal.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: 4 groups of 4 letters separated by dashes. The “apple_id” field is filled in the main form."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Format : 4 groupes de 4 lettres séparés par des tirets. Le champ « apple_id » est rempli dans le formulaire principal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato: 4 grupos de 4 letras separados por guiones. El campo «apple_id» se completa en el formulario principal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato: 4 gruppi di 4 lettere separati da trattini. Il campo «apple_id» si compila nel modulo principale."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: 4 Gruppen mit je 4 Buchstaben, durch Bindestriche getrennt. Das Feld „apple_id“ wird im Hauptformular ausgefüllt."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Formato: 4 grupos de 4 letras separados por hífens. O campo “apple_id” é preenchido no formulário principal."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Notatie: 4 groepen van 4 letters gescheiden door streepjes. Het veld “apple_id” wordt in het hoofdformulier ingevuld."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Формат: 4 группы по 4 буквы, разделённые дефисами. Поле «apple_id» заполняется в основной форме."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Format: 4 grupy po 4 litery oddzielone myślnikami. Pole „apple_id” wypełnia się w głównym formularzu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "形式: ハイフンで区切られた 4 文字 4 グループ。「apple_id」フィールドはメインフォームで入力します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "형식: 하이픈으로 구분된 4자 4그룹. “apple_id” 필드는 기본 양식에서 입력합니다."
          }
        }
      }
    },
