    "« Standard » chiffre noms de fichiers et dossiers. « En clair » garde les noms lisibles (utile pour retrouver des fichiers côté fournisseur).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“Standard” encrypts file and folder names. “Plain” keeps names readable (handy to find files on the provider side)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«Standard» cifra i nomi di file e cartelle. «Plain» mantiene i nomi leggibili (utile per trovare i file sul lato provider)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "“標準”はファイル名とフォルダ名を暗号化します。“平文”は名前を読める状態のまま保ちます（プロバイダ側でファイルを探すのに便利）。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "“Padrão” criptografa os nomes de arquivos e pastas. “Texto puro” mantém os nomes legíveis (útil para encontrar arquivos do lado do provedor)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Standard» cifra los nombres de archivos y carpetas. «Plain» mantiene los nombres legibles (útil para encontrar archivos en el proveedor)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Standard“ verschlüsselt Datei- und Ordnernamen. „Plain“ hält die Namen lesbar (praktisch, um Dateien auf der Anbieterseite zu finden)."
          }
        }
      }
    },
