    "Les fichiers suivants seront écrasés sans possibilité d'annulation : %@%@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die folgenden Dateien werden ohne Rückgängigmachen überschrieben: %1$@%2$@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The following files will be overwritten with no undo: %1$@%2$@."
          }
        },
        "fr": {
