    "Un élément existe déjà à %@. Renommez-le ou déplacez-le avant de restaurer.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei %@ existiert bereits ein Objekt. Benenne es um oder verschiebe es, bevor du wiederherstellst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An item already exists at %@. Rename or move it before restoring."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un élément existe déjà à %@. Renommez-le ou déplacez-le avant de restaurer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Element już istnieje w %@. Zmień jego nazwę lub przenieś go przed przywróceniem."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já existe um item em %@. Renomeie-o ou mova-o antes de restaurar."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe un elemento en %@. Renómbralo o muévelo antes de restaurar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esiste già un elemento in %@. Rinominalo o spostalo prima di ripristinare."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er bestaat al een item op %@. Wijzig de naam of verplaats het vóór het herstellen."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "В %@ уже существует объект. Переименуйте или переместите его перед восстановлением."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ にはすでに項目が存在します。復元する前に名称変更または移動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@에 이미 항목이 있습니다. 복원하기 전에 이름을 변경하거나 이동하세요."
          }
        }
      }
    },
    "Un Live Photo reste une photo : décocher l'option ne supprime pas la photo principale, ça ignore juste la composante vidéo liée.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Live Photo ist trotzdem ein Foto: Das Abwählen der Option entfernt nicht das Hauptfoto, es ignoriert nur die verknüpfte Videokomponente."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Live Photo is still a photo: unchecking the option doesn’t remove the main photo, it just ignores the linked video component."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una Live Photo sigue siendo una foto: desmarcar la opción no elimina la foto principal, solo ignora el componente de vídeo vinculado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un Live Photo reste une photo : décocher l'option ne supprime pas la photo principale, ça ignore juste la composante vidéo liée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una Live Photo è comunque una foto: deselezionare l'opzione non rimuove la foto principale, ignora solo la componente video collegata."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Live Photo to wciąż zdjęcie: odznaczenie opcji nie usuwa głównego zdjęcia, jedynie ignoruje powiązany komponent wideo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um Live Photo ainda é uma foto: desmarcar a opção não remove a foto principal, apenas ignora o componente de vídeo vinculado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Live Photo — это всё равно фото: снятие флажка не удаляет основное фото, оно лишь игнорирует связанный видеокомпонент."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een Live Photo is toch een foto: het uitvinken van de optie verwijdert de hoofdfoto niet, het negeert alleen de gekoppelde videocomponent."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Live Photo もやはり写真です: オプションのチェックを外してもメイン写真は削除されず、リンクされたビデオ要素が無視されるだけです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Live Photo도 사진입니다: 옵션 선택을 해제해도 기본 사진은 제거되지 않으며, 연결된 비디오 구성 요소만 무시됩니다."
          }
        }
      }
    },
