    "Quand le cache atteint cette taille, les fichiers les plus anciens sont effacés en premier (LRU — Phase E2).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When the cache reaches this size, the oldest files are erased first (LRU — Phase E2)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand le cache atteint cette taille, les fichiers les plus anciens sont effacés en premier (LRU — Phase E2)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Gdy pamięć podręczna osiągnie ten rozmiar, najstarsze pliki są usuwane jako pierwsze (LRU — Phase E2)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "当缓存达到这个大小时，最旧的文件会被优先清除（LRU — Phase E2）。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando la caché alcanza este tamaño, los archivos más antiguos se borran primero (LRU — fase E2)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando la cache raggiunge questa dimensione, i file più vecchi vengono cancellati per primi (LRU — fase E2)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn der Cache diese Größe erreicht, werden die ältesten Dateien zuerst gelöscht (LRU — Phase E2)."
          }
        }
      }
    },
