    "Vérification d'intégrité, %lld vérifiés, %lld manquants, %lld hash différents, %lld non vérifiables sur %lld au total": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Integrity check, %1$lld verified, %2$lld missing, %3$lld different hashes, %4$lld unverifiable out of %5$lld total"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérification d'intégrité, %1$lld vérifiés, %2$lld manquants, %3$lld hash différents, %4$lld non vérifiables sur %5$lld au total"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comprobación de integridad, %1$lld verificados, %2$lld faltan, %3$lld hashes diferentes, %4$lld no verificables de %5$lld en total"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controllo di integrità, %1$lld verificati, %2$lld mancanti, %3$lld hash diversi, %4$lld non verificabili su %5$lld totali"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Integritätsprüfung, %1$lld verifiziert, %2$lld fehlend, %3$lld unterschiedliche Hashes, %4$lld nicht überprüfbar von %5$lld insgesamt"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Verificação de integridade, %1$lld verificados, %2$lld ausentes, %3$lld hashes diferentes, %4$lld não verificáveis de %5$lld no total"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Integriteitscontrole, %1$lld geverifieerd, %2$lld ontbrekend, %3$lld verschillende hashes, %4$lld niet verifieerbaar van %5$lld in totaal"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверка целостности: %1$lld проверено, %2$lld отсутствует, %3$lld разных хешей, %4$lld не проверяется из %5$lld всего"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sprawdzenie integralności: %1$lld zweryfikowano, %2$lld brakuje, %3$lld różnych haszy, %4$lld nieweryfikowalnych z %5$lld łącznie"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "整合性チェック、検証 %1$lld 件、欠落 %2$lld 件、ハッシュ相違 %3$lld 件、検証不可 %4$lld 件、合計 %5$lld 件中"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무결성 검사, %1$lld개 검증됨, %2$lld개 누락, %3$lld개 해시 불일치, %4$lld개 검증 불가, 총 %5$lld개 중"
          }
        }
      }
    },
