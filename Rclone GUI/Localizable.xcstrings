            "state": "translated",
            "value": "Агрегированное резервное копирование медиатеки фото через rclone copy."
          }
        }
      }
    },
    "Sauvegarde toute ta photothèque vers ton remote rclone, en pipeline batché, avec dédup pré-export et reprise auto.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Backs up your entire photo library to your rclone remote, in a batched pipeline, with pre-export dedup and auto-resume."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sauvegarde toute ta photothèque vers ton remote rclone, en pipeline batché, avec dédup pré-export et reprise auto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esegue il backup dell'intera libreria foto sul tuo remoto rclone, in una pipeline a lotti, con deduplica prima dell'esportazione e ripresa automatica."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "把你的整个照片图库备份到你的 rclone remote，采用批处理流水线，导出前去重并自动续传。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hace una copia de toda tu fototeca en tu remoto de rclone, en una canalización por lotes, con deduplicación previa a la exportación y reanudación automática."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sichert deine gesamte Fotomediathek auf dein rclone-Remote, in einer stapelweisen Pipeline, mit Deduplizierung vor dem Export und automatischer Fortsetzung."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faz backup de toda a sua fototeca no seu remoto do rclone, em um pipeline em lotes, com deduplicação antes da exportação e retomada automática."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Maakt een back-up van je hele fotobibliotheek naar je rclone-remote, in een batchpijplijn, met deduplicatie vóór export en automatisch hervatten."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создаёт резервную копию всей вашей медиатеки фото в ваш remote rclone в пакетном конвейере, с дедупликацией перед экспортом и автоматическим возобновлением."
          }
        }
      }
    },
