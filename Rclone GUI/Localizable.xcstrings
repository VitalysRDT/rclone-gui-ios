          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Interactive mode is compatible with 100% of rclone backends, including those not listed in the graphical catalog."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo interactivo es compatible con el 100% de los backends de rclone, incluidos los que no figuran en el catálogo gráfico."
