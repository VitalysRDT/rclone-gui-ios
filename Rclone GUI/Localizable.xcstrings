    "Les vidéos plus longues que ce seuil sont sautées. Les photos ne sont pas affectées (elles sont toujours petites)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Videos, die länger als dieser Schwellenwert sind, werden übersprungen. Fotos sind nicht betroffen (sie sind immer klein)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Videos longer than this threshold are skipped. Photos are not affected (they’re always small)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los vídeos más largos que este umbral se omiten. Las fotos no se ven afectadas (siempre son pequeñas)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les vidéos plus longues que ce seuil sont sautées. Les photos ne sont pas affectées (elles sont toujours petites)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I video più lunghi di questa soglia vengono saltati. Le foto non sono interessate (sono sempre piccole)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このしきい値より長いビデオはスキップされます。写真は影響を受けません（常に小さいため）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 임계값보다 긴 비디오는 건너뜁니다. 사진은 영향을 받지 않습니다(항상 작음)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Video's die langer zijn dan deze drempel worden overgeslagen. Foto's worden niet beïnvloed (ze zijn altijd klein)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filmy dłuższe niż ten próg są pomijane. Zdjęcia nie są objęte (są zawsze małe)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vídeos mais longos que este limite são ignorados. As fotos não são afetadas (são sempre pequenas)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Видео длиннее этого порога пропускаются. Фото не затрагиваются (они всегда небольшие)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
