            "value": "Clears the trial anchor (Keychain + iCloud) to replay the 7 days. Excluded from App Store builds."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Usuwa kotwicę okresu próbnego (Keychain + iCloud), aby ponownie przejść 7 dni. Niedostępne w buildzie App Store."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
