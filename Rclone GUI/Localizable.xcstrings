    "Le sujet inclut automatiquement la version de l'app pour accélérer le diagnostic. Réponse généralement sous quelques jours.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The subject automatically includes the app version to speed up diagnosis. You'll usually get a reply within a few days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El asunto incluye automáticamente la versión de la app para agilizar el diagnóstico. Normalmente recibirás una respuesta en unos días."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'oggetto include automaticamente la versione dell'app per velocizzare la diagnosi. Di solito riceverai una risposta entro pochi giorni."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Betreff enthält automatisch die App-Version, um die Diagnose zu beschleunigen. In der Regel erhältst du innerhalb weniger Tage eine Antwort."
          }
        },
        "pt-BR": {
