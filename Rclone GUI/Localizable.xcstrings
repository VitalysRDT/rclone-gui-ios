    "Fichiers téléchargés temporairement pour la lecture. Tu peux les purger à tout moment." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dateien, die vorübergehend zur Wiedergabe heruntergeladen wurden. Du kannst sie jederzeit bereinigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Files downloaded temporarily for playback. You can purge them at any time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivos descargados temporalmente para la reproducción. Puedes purgarlos en cualquier momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fichiers téléchargés temporairement pour la lecture. Tu peux les purger à tout moment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "File scaricati temporaneamente per la riproduzione. Puoi eliminarli in qualsiasi momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再生のために一時的にダウンロードされたファイル。いつでも消去できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "재생을 위해 임시로 다운로드된 파일. 언제든지 비울 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bestanden die tijdelijk zijn gedownload voor afspelen. Je kunt ze op elk moment opschonen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pliki pobrane tymczasowo do odtwarzania. Możesz je wyczyścić w dowolnym momencie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arquivos baixados temporariamente para reprodução. Você pode limpá-los a qualquer momento."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Файлы, временно загруженные для воспроизведения. Вы можете очистить их в любой момент."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
