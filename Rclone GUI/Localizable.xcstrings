    "Quand le cache atteint cette taille, les fichiers les plus anciens sont effacés en premier (LRU — Phase E2)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn der Cache diese Größe erreicht, werden die ältesten Dateien zuerst gelöscht (LRU — Phase E2)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the cache reaches this size, the oldest files are erased first (LRU — Phase E2)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando la caché alcanza este tamaño, los archivos más antiguos se borran primero (LRU — fase E2)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quand le cache atteint cette taille, les fichiers les plus anciens sont effacés en premier (LRU — Phase E2)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando la cache raggiunge questa dimensione, i file più vecchi vengono cancellati per primi (LRU — fase E2)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャッシュがこのサイズに達すると、最も古いファイルから順に消去されます（LRU — フェーズ E2）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캐시가 이 크기에 도달하면 가장 오래된 파일부터 삭제됩니다(LRU — E2 단계)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer de cache deze grootte bereikt, worden de oudste bestanden als eerste gewist (LRU — fase E2)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gdy pamięć podręczna osiągnie ten rozmiar, najstarsze pliki są usuwane jako pierwsze (LRU — faza E2)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando o cache atinge esse tamanho, os arquivos mais antigos são apagados primeiro (LRU — Fase E2)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Когда кэш достигает этого размера, самые старые файлы стираются первыми (LRU — фаза E2)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当缓存达到此大小时，会首先擦除最旧的文件（LRU —— E2 阶段）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當快取達到此大小時，會首先擦除最舊的檔案（LRU —— E2 階段）。"
          }
        }
      }
    },
