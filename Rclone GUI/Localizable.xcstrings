    "Emplacement du coffre dans le remote. Laisse à la racine pour chiffrer tout le remote.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Where the vault lives in the remote. Leave at the root to encrypt the whole remote."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保管庫がリモート内のどこに存在するか。リモート全体を暗号化するにはルートのままにします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보관함이 리모트 내 어디에 있는지. 리모트 전체를 암호화하려면 루트로 두세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Waar de kluis in de remote staat. Laat het in de root staan om de hele remote te versleutelen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "保险库在 remote 中的位置。保持在根目录即可加密整个 remote。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dónde reside la bóveda en el remoto. Déjalo en la raíz para cifrar todo el remoto."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dove risiede la cassaforte nel remoto. Lasciala nella radice per cifrare l'intero remoto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wo der Tresor im Remote liegt. Belasse ihn in der Wurzel, um das gesamte Remote zu verschlüsseln."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Onde o cofre reside no remoto. Deixe na raiz para criptografar todo o remoto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Где сейф находится в remote. Оставьте в корне, чтобы зашифровать весь remote."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdzie sejf znajduje się w remote. Pozostaw w katalogu głównym, aby zaszyfrować cały remote."
          }
        }
      }
    },
