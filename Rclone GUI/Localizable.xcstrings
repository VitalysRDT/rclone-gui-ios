    "Le dossier et tout son contenu peuvent être restaurés depuis la corbeille pendant 30 jours, ou supprimés définitivement.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The folder and all its contents can be restored from the trash for 30 days, or deleted permanently."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dossier et tout son contenu peuvent être restaurés depuis la corbeille pendant 30 jours, ou supprimés définitivement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La cartella e tutto il suo contenuto possono essere ripristinati dal Cestino per 30 giorni, oppure eliminati definitivamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "De map en alle inhoud kunnen 30 dagen lang vanuit de prullenmand worden hersteld of definitief worden verwijderd."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "這個資料夾及其所有內容可在 30 天內從垃圾桶還原，或永久刪除。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La carpeta y todo su contenido se pueden restaurar desde la papelera durante 30 días, o eliminarse de forma permanente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Ordner und sein gesamter Inhalt können 30 Tage lang aus dem Papierkorb wiederhergestellt oder endgültig gelöscht werden."
          }
        }
      }
    },
    "Le fichier de destination sera écrasé sans possibilité d'annulation. La version remplacée n'est pas envoyée à la corbeille.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The destination file will be overwritten with no undo. The replaced version is not sent to the trash."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo de destino se sobrescribirá sin posibilidad de deshacer. La versión reemplazada no se envía a la papelera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier de destination sera écrasé sans possibilité d'annulation. La version remplacée n'est pas envoyée à la corbeille."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il file di destinazione verrà sovrascritto senza possibilità di annullamento. La versione sostituita non viene inviata al Cestino."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "O arquivo de destino será substituído sem possibilidade de desfazer. A versão substituída não é enviada para a lixeira."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Файл назначения будет перезаписан без возможности отмены. Заменённая версия не отправляется в корзину."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Zieldatei wird ohne Rückgängigmachen überschrieben. Die ersetzte Version wird nicht in den Papierkorb verschoben."
          }
        }
      }
    },
    "Le fichier peut être restauré depuis la corbeille pendant 30 jours, ou supprimé définitivement.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file can be restored from the trash for 30 days, or deleted permanently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo se puede restaurar desde la papelera durante 30 días, o eliminarse de forma permanente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier peut être restauré depuis la corbeille pendant 30 jours, ou supprimé définitivement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il file può essere ripristinato dal Cestino per 30 giorni, oppure eliminato definitivamente."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Datei kann 30 Tage lang aus dem Papierkorb wiederhergestellt oder endgültig gelöscht werden."
          }
        }
      }
    },
    "Le fichier sera chiffré et stocké localement. Tes clés ne quittent jamais l’iPhone.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Datei wird verschlüsselt und lokal gespeichert. Deine Schlüssel verlassen niemals das iPhone."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file will be encrypted and stored locally. Your keys never leave the iPhone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo se cifrará y se almacenará localmente. Tus claves nunca salen del iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier sera chiffré et stocké localement. Tes clés ne quittent jamais l’iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il file verrà cifrato e archiviato localmente. Le tue chiavi non lasciano mai l'iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "ファイルは暗号化されてローカルに保存されるよ。鍵が iPhone の外に出ることは絶対にないよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "파일은 암호화돼 기기에 저장돼. 네 키는 절대 iPhone 밖으로 나가지 않아."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Het bestand wordt versleuteld en lokaal opgeslagen. Je sleutels verlaten nooit de iPhone."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Plik zostanie zaszyfrowany i zapisany lokalnie. Twoje klucze nigdy nie opuszczają iPhone’a."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "O arquivo será criptografado e armazenado localmente. Suas chaves nunca saem do iPhone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Файл будет зашифрован и сохранён локально. Твои ключи никогда не покидают iPhone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "文件将被加密并存储在本机。你的密钥永远不会离开 iPhone。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "檔案會被加密並儲存在本機。你的金鑰永遠不會離開 iPhone。"
          }
        }
      }
    },
    "Le fichier sera chiffré et stocké localement. Tes clés ne quittent jamais ton appareil.": {
