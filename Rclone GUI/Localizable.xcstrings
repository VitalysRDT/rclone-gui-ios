        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "체험 앵커(Keychain + iCloud)를 지워 7일을 다시 시작합니다. App Store 빌드에서는 제외됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
