    "Importe ton rclone.conf pour afficher tes remotes et parcourir tes fichiers.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import your rclone.conf to show your remotes and browse your files."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa tu rclone.conf para mostrar tus remotos y explorar tus archivos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa il tuo rclone.conf per mostrare i tuoi remoti ed esplorare i tuoi file."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importiere deine rclone.conf, um deine Remotes anzuzeigen und deine Dateien zu durchsuchen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe seu rclone.conf para mostrar seus remotos e navegar pelos seus arquivos."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Importeer je rclone.conf om je remotes te tonen en door je bestanden te bladeren."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Импортируйте ваш rclone.conf, чтобы показать ваши remote и просматривать файлы."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaimportuj swój rclone.conf, aby wyświetlić swoje remote i przeglądać pliki."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リモートを表示してファイルを閲覧するには、rclone.conf をインポートしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "리모트를 표시하고 파일을 탐색하려면 rclone.conf를 가져오세요."
          }
        }
      }
    },
    "Importe ton rclone.conf pour parcourir tes remotes, synchroniser tes fichiers et exposer tes dossiers dans Fichiers.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import your rclone.conf to browse your remotes, sync your files and expose your folders in Files."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe ton rclone.conf pour parcourir tes remotes, synchroniser tes fichiers et exposer tes dossiers dans Fichiers."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa il tuo rclone.conf per esplorare i tuoi remoti, sincronizzare i tuoi file ed esporre le tue cartelle in File."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "리모트를 탐색하고, 파일을 동기화하고, 폴더를 “파일”에 노출하려면 rclone.conf를 가져오세요."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa tu rclone.conf para explorar tus remotos, sincronizar tus archivos y exponer tus carpetas en Archivos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importiere deine rclone.conf, um deine Remotes zu durchsuchen, deine Dateien zu synchronisieren und deine Ordner in „Dateien“ bereitzustellen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe seu rclone.conf para navegar pelos seus remotos, sincronizar seus arquivos e expor suas pastas em Arquivos."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Importeer je rclone.conf om door je remotes te bladeren, je bestanden te synchroniseren en je mappen beschikbaar te maken in Bestanden."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Импортируйте ваш rclone.conf, чтобы просматривать ваши remote, синхронизировать файлы и предоставлять папки в «Файлах»."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaimportuj swój rclone.conf, aby przeglądać swoje remote, synchronizować pliki i udostępniać foldery w Plikach."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リモートを閲覧し、ファイルを同期し、フォルダを「ファイル」に公開するには、rclone.conf をインポートしてください。"
          }
        }
      }
    },
