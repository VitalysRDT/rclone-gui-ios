            "value" : "Chaque élément garde son nom et sera placé dans le dossier cible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ogni elemento mantiene il proprio nome e verrà collocato nella cartella di destinazione."
