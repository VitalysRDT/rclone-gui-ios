    "Active la 2FA sur ton compte iCloud si pas déjà fait (obligatoire).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable 2FA on your iCloud account if not already done (required)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Active la 2FA sur ton compte iCloud si pas déjà fait (obligatoire)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa la 2FA en tu cuenta de iCloud si aún no lo has hecho (obligatorio)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva la 2FA sul tuo account iCloud se non l'hai già fatto (obbligatorio)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere die 2FA für dein iCloud-Konto, falls noch nicht geschehen (erforderlich)."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative a 2FA na sua conta do iCloud, se ainda não fez (obrigatório)."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel 2FA in op je iCloud-account als dat nog niet is gebeurd (vereist)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите 2FA для вашей учётной записи iCloud, если ещё не сделали этого (обязательно)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz 2FA na swoim koncie iCloud, jeśli jeszcze tego nie zrobiłeś (wymagane)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ有効にしていない場合は、iCloud アカウントで 2FA を有効にしてください（必須）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 설정하지 않았다면 iCloud 계정에서 2FA를 활성화하세요(필수)."
          }
        }
      }
    },
