    "La configuration est chargée, mais le moteur RcloneKit réel n’est pas disponible dans cette session.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The configuration is loaded, but the real RcloneKit engine isn’t available in this session."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La configuration est chargée, mais le moteur RcloneKit réel n’est pas disponible dans cette session."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La configurazione è caricata, ma il vero motore RcloneKit non è disponibile in questa sessione."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La configuración está cargada, pero el motor real RcloneKit no está disponible en esta sesión."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Konfiguration ist geladen, aber die echte RcloneKit-Engine ist in dieser Sitzung nicht verfügbar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A configuração está carregada, mas o mecanismo real RcloneKit não está disponível nesta sessão."
          }
        },
        "nl": {
