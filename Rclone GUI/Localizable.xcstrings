    "À l'étape précédente du wizard, remplis aussi « apple_id » avec ton email Apple ID.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On the previous wizard step, also fill in “apple_id” with your Apple ID email."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En el paso anterior del asistente, completa también «apple_id» con el correo de tu Apple ID."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À l'étape précédente du wizard, remplis aussi « apple_id » avec ton email Apple ID."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nel passaggio precedente della procedura guidata, compila anche «apple_id» con l'email del tuo Apple ID."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Trage im vorherigen Assistentenschritt auch „apple_id“ mit der E-Mail deiner Apple-ID ein."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Na etapa anterior do assistente, preencha também “apple_id” com o e-mail do seu Apple ID."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vul in de vorige wizardstap ook “apple_id” in met het e-mailadres van je Apple ID."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На предыдущем шаге мастера также заполните «apple_id» адресом e-mail вашего Apple ID."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W poprzednim kroku asystenta wpisz także „apple_id” z adresem e-mail Twojego Apple ID."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前のウィザード手順で、「apple_id」にも Apple ID のメールアドレスを入力してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 마법사 단계에서 “apple_id”에도 Apple ID 이메일을 입력하세요."
          }
        }
      }
    },
    "À l'étape précédente du wizard, remplis aussi « email » et « password » (les identifiants Linkbox classiques) dans le formulaire principal.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On the previous wizard step, also fill in “email” and “password” (the usual Linkbox credentials) in the main form."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À l'étape précédente du wizard, remplis aussi « email » et « password » (les identifiants Linkbox classiques) dans le formulaire principal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На предыдущем шаге мастера также заполните «email» и «password» (обычные учётные данные Linkbox) в основной форме."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En el paso anterior del asistente, completa también «email» y «password» (las credenciales habituales de Linkbox) en el formulario principal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nel passaggio precedente della procedura guidata, compila anche «email» e «password» (le solite credenziali di Linkbox) nel modulo principale."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Trage im vorherigen Assistentenschritt auch „email“ und „password“ (die üblichen Linkbox-Zugangsdaten) im Hauptformular ein."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Na etapa anterior do assistente, preencha também “email” e “password” (as credenciais habituais do Linkbox) no formulário principal."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vul in de vorige wizardstap ook “email” en “password” (de gebruikelijke Linkbox-inloggegevens) in het hoofdformulier in."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W poprzednim kroku asystenta wpisz także „email” i „password” (zwykłe dane logowania Linkbox) w głównym formularzu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "前のウィザード手順で、メインフォームの「email」と「password」（通常の Linkbox 認証情報）も入力してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이전 마법사 단계에서 기본 양식의 “email”과 “password”(일반적인 Linkbox 자격 증명)도 입력하세요."
          }
        }
      }
    },
