    "Le sujet inclut automatiquement la version de l'app pour accélérer le diagnostic. Réponse généralement sous quelques jours.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The subject automatically includes the app version to speed up diagnosis. You'll usually get a reply within a few days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
