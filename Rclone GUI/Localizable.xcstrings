    "Si ton rclone.conf est protégé par un mot de passe rclone, il sera demandé à la lecture. Stocké en Keychain et protégé par Face ID.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deine rclone.conf durch ein rclone-Passwort geschützt ist, wird es beim Lesen angefordert. Im Keychain gespeichert und durch Face ID geschützt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your rclone.conf is protected by an rclone password, it will be requested when reading. Stored in the Keychain and protected by Face ID."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tu rclone.conf está protegido con una contraseña de rclone, se solicitará al leerlo. Se almacena en el Keychain y se protege con Face ID."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si ton rclone.conf est protégé par un mot de passe rclone, il sera demandé à la lecture. Stocké en Keychain et protégé par Face ID."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il tuo rclone.conf è protetto da una password di rclone, verrà richiesta alla lettura. Memorizzata nel Keychain e protetta da Face ID."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "rclone.conf が rclone のパスワードで保護されている場合、読み込み時に入力を求められるよ。Keychain に保存され、Face IDで保護されるよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "rclone.conf가 rclone 비밀번호로 보호돼 있으면 읽을 때 비밀번호를 물어봐. Keychain에 저장되고 Face ID로 보호돼."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als je rclone.conf is beschermd met een rclone-wachtwoord, wordt dit bij het lezen gevraagd. Opgeslagen in de Keychain en beschermd met Face ID."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Jeśli Twój plik rclone.conf jest chroniony hasłem rclone, zostanie ono poproszone przy odczycie. Przechowywane w Keychain i chronione przez Face ID."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se seu rclone.conf estiver protegido por uma senha do rclone, ela será solicitada na leitura. Armazenada no Keychain e protegida pelo Face ID."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если ваш rclone.conf защищён паролем rclone, он будет запрошен при чтении. Хранится в Keychain и защищён Face ID."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "如果你的 rclone.conf 受 rclone 密码保护，读取时会提示你输入。它存储在 Keychain 中，并由 Face ID 保护。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "如果你的 rclone.conf 受 rclone 密碼保護，讀取時系統會要求輸入。會儲存在 Keychain 並由 Face ID 保護。"
          }
        }
      }
    },
    "Si ton rclone.conf est protégé par un mot de passe rclone, il sera demandé à la lecture. Stocké en Keychain et protégé par la biométrie.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deine rclone.conf durch ein rclone-Passwort geschützt ist, wird es beim Lesen abgefragt. Im Keychain gespeichert und durch Biometrie geschützt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If your rclone.conf is protected by an rclone password, it will be asked when reading. Stored in Keychain and protected by biometrics."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si tu rclone.conf está protegido con una contraseña de rclone, se pedirá al leerlo. Se almacena en el Keychain y se protege con biometría."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il tuo rclone.conf è protetto da una password di rclone, verrà richiesta alla lettura. Memorizzata nel Keychain e protetta dalla biometria."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "rclone.conf が rclone のパスワードで保護されている場合、読み込み時に入力を求められるよ。Keychain に保存され、生体認証で保護されるよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "rclone.conf가 rclone 비밀번호로 보호돼 있으면 읽을 때 비밀번호를 물어봐. Keychain에 저장되고 생체 인증으로 보호돼."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als je rclone.conf is beschermd met een rclone-wachtwoord, wordt dit bij het lezen gevraagd. Opgeslagen in de Keychain en beschermd met biometrie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Jeśli Twój plik rclone.conf jest chroniony hasłem rclone, zostanie ono poproszone przy odczycie. Przechowywane w Keychain i chronione biometrią."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se seu rclone.conf estiver protegido por uma senha do rclone, ela será solicitada na leitura. Armazenada no Keychain e protegida por biometria."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если ваш rclone.conf защищён паролем rclone, он будет запрошен при чтении. Хранится в Keychain и защищён биометрией."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "如果你的 rclone.conf 受 rclone 密码保护，读取时会提示你输入。它存储在 Keychain 中，并由生物识别保护。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "如果你的 rclone.conf 受 rclone 密碼保護，讀取時系統會要求輸入。會儲存在 Keychain 並由生物辨識保護。"
          }
        }
      }
    },
