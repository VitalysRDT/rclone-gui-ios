    "Pour HiDrive, le plus simple est `rclone authorize \"hidrive\"` sur un poste avec navigateur." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für HiDrive ist `rclone authorize \"hidrive\"` auf einem Rechner mit Browser am einfachsten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For HiDrive, the easiest is `rclone authorize \"hidrive\"` on a machine with a browser."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para HiDrive, lo más fácil es `rclone authorize \"hidrive\"` en una máquina con navegador."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour HiDrive, le plus simple est `rclone authorize \"hidrive\"` sur un poste avec navigateur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per HiDrive, il più semplice è `rclone authorize \"hidrive\"` su una macchina con un browser."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HiDrive の場合、最も簡単なのはブラウザのあるマシンで `rclone authorize \"hidrive\"` です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HiDrive의 경우, 브라우저가 있는 컴퓨터에서 `rclone authorize \"hidrive\"`가 가장 간단합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voor HiDrive is `rclone authorize \"hidrive\"` op een machine met een browser het eenvoudigst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "W przypadku HiDrive najprościej jest `rclone authorize \"hidrive\"` na maszynie z przeglądarką."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para o HiDrive, o mais fácil é `rclone authorize \"hidrive\"` em uma máquina com navegador."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для HiDrive проще всего `rclone authorize \"hidrive\"` на машине с браузером."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "对于 HiDrive，最简单的方法是在有浏览器的机器上运行 `rclone authorize \"hidrive\"`。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "對於 HiDrive，最簡單的方法是在有瀏覽器的機器上執行 `rclone authorize \"hidrive\"`。"
          }
        }
      }
