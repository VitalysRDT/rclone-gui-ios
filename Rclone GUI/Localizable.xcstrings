        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Replica `rclone config`: útil para crypt, alias, union, combine y cualquier backend que requiera indicaciones dinámicas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Replica `rclone config`: utile per crypt, alias, union, combine e qualsiasi backend che richieda richieste dinamiche."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
