    },
    "Un Live Photo reste une photo : décocher l'option ne supprime pas la photo principale, ça ignore juste la composante vidéo liée.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Live Photo ist trotzdem ein Foto: Das Abwählen der Option entfernt nicht das Hauptfoto, es ignoriert nur die verknüpfte Videokomponente."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Live Photo is still a photo: unchecking the option doesn’t remove the main photo, it just ignores the linked video component."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una Live Photo sigue siendo una foto: desmarcar la opción no elimina la foto principal, solo ignora el componente de vídeo vinculado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un Live Photo reste une photo : décocher l'option ne supprime pas la photo principale, ça ignore juste la composante vidéo liée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una Live Photo è comunque una foto: deselezionare l'opzione non rimuove la foto principale, ignora solo la componente video collegata."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Live Photo to wciąż zdjęcie: odznaczenie tej opcji nie usuwa głównego zdjęcia, pomija tylko powiązaną część wideo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Um Live Photo continua sendo uma foto: desmarcar a opção não remove a foto principal, só ignora o componente de vídeo vinculado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Live Photo всё равно остаётся фото: снятие этой опции не удаляет основное фото, а лишь игнорирует связанную видеосоставляющую."
          }
        }
      }
    },
