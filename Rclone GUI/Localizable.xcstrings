          }
        }
      }
    },
    "Le remote « %@ » sera retiré de rclone.conf. Tes fichiers distants ne sont pas supprimés.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "The remote “%@” will be removed from rclone.conf. Your remote files are not deleted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El remoto «%@» se eliminará de rclone.conf. Tus archivos remotos no se eliminan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il remoto «%@» verrà rimosso da rclone.conf. I tuoi file remoti non vengono eliminati."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Remote „%@“ wird aus der rclone.conf entfernt. Deine Remote-Dateien werden nicht gelöscht."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O remoto “%@” será removido do rclone.conf. Seus arquivos remotos não são excluídos."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De remote “%@” wordt uit rclone.conf verwijderd. Je remotebestanden worden niet verwijderd."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Remote «%@» будет удалён из rclone.conf. Ваши удалённые файлы не удаляются."
          }
        }
      }
    },
    "Le remote sera créé après un test réussi. Si le test échoue de manière connue, tu peux quand même créer le remote.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Remote wird nach einem erfolgreichen Test erstellt. Wenn der Test auf bekannte Weise fehlschlägt, kannst du das Remote trotzdem erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The remote will be created after a successful test. If the test fails in a known way, you can still create the remote."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le remote sera créé après un test réussi. Si le test échoue de manière connue, tu peux quand même créer le remote."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il remoto verrà creato dopo un test riuscito. Se il test fallisce in modo noto, puoi comunque creare il remoto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "remote はテストに成功すると作成されるよ。テストが既知の理由で失敗した場合でも、remote を作成できるよ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "remote는 테스트에 성공하면 생성돼. 테스트가 알려진 방식으로 실패해도 remote를 그냥 생성할 수 있어."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De remote wordt aangemaakt na een geslaagde test. Als de test op een bekende manier mislukt, kun je de remote toch aanmaken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "remote zostanie utworzony po udanym teście. Jeśli test zakończy się znanym błędem, i tak możesz utworzyć remote."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O remoto será criado após um teste bem-sucedido. Se o teste falhar de forma conhecida, você ainda pode criar o remoto."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Remote будет создан после успешного теста. Если тест завершится известной ошибкой, вы всё равно можете создать remote."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "测试成功后会创建 remote。如果测试以已知的方式失败，你仍然可以创建 remote。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "測試成功後就會建立 remote。如果測試是以已知的方式失敗，你還是可以建立 remote。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El remoto se creará tras una prueba correcta. Si la prueba falla de forma conocida, aún puedes crear el remoto."
          }
        }
      }
    },
    "Le serveur ne répond pas. Vérifie ta connexion ou tes paramètres.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The server isn’t responding. Check your connection or your settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur ne répond pas. Vérifie ta connexion ou tes paramètres."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De server reageert niet. Controleer je verbinding of je instellingen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El servidor no responde. Comprueba tu conexión o tus ajustes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il server non risponde. Controlla la tua connessione o le tue impostazioni."
          }
        },
        "de": {
