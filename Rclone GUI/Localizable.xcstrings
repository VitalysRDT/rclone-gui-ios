          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedes Objekt behält seinen Namen und wird im Zielordner abgelegt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each item keeps its name and will be placed in the target folder."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada elemento conserva su nombre y se colocará en la carpeta de destino."
          }
        },
        "fr" : {
          "stringUnit" : {
