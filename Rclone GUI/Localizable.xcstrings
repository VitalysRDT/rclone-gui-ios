    "Étape 1 : sélectionne « Drive API v3 → https://www.googleapis.com/auth/drive » puis clique « Authorize APIs »." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schritt 1: Wähle „Drive API v3 → https://www.googleapis.com/auth/drive“ und klicke dann auf „Authorize APIs“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Step 1: select “Drive API v3 → https://www.googleapis.com/auth/drive” then click “Authorize APIs”."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
