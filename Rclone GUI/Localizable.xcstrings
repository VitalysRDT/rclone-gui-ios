          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Replica o `rclone config` — útil para crypt, alias, union, combine e qualquer backend que exija prompts dinâmicos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Воспроизводит `rclone config` — полезно для crypt, alias, union, combine и любого бэкенда, требующего динамических запросов."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
