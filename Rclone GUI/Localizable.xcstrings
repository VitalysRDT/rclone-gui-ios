    "Cette action est irréversible. Tu pourras ré-importer ton rclone.conf après." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Diese Aktion ist unwiderruflich. Du kannst deine rclone.conf danach erneut importieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This action is irreversible. You can re-import your rclone.conf afterwards."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Esta acción es irreversible. Podrás volver a importar tu rclone.conf después."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action est irréversible. Tu pourras ré-importer ton rclone.conf après."
