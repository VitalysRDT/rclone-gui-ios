          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usuwa lokalnie zaszyfrowany rclone.conf i klucz główny Keychain. Później możesz zaimportować ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
