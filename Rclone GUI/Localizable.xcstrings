            "state": "translated",
            "value": "De configuratie is geladen, maar de echte RcloneKit-engine is niet beschikbaar in deze sessie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Конфигурация загружена, но настоящий движок RcloneKit недоступен в этом сеансе."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfiguracja jest wczytana, ale prawdziwy silnik RcloneKit nie jest dostępny w tej sesji."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定は読み込まれていますが、このセッションでは実際の RcloneKit エンジンを利用できません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
