    "Réplique `rclone config` — utile pour crypt, alias, union, combine et tout backend exigeant des prompts dynamiques.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Replicates `rclone config` — useful for crypt, alias, union, combine and any backend requiring dynamic prompts."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réplique `rclone config` — utile pour crypt, alias, union, combine et tout backend exigeant des prompts dynamiques."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "`rclone config`를 재현해 — crypt, alias, union, combine 및 동적 프롬프트가 필요한 모든 백엔드에 유용해."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "machine_translated",
            "value": "Bootst `rclone config` na — handig voor crypt, alias, union, combine en elke backend die dynamische prompts vereist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Replica `rclone config`: útil para crypt, alias, union, combine y cualquier backend que requiera indicaciones dinámicas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Replica `rclone config`: utile per crypt, alias, union, combine e qualsiasi backend che richieda richieste dinamiche."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bildet `rclone config` nach — nützlich für crypt, alias, union, combine und jedes Backend, das dynamische Eingaben erfordert."
          }
        }
      }
    },
