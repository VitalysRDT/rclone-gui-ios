    "Seules les photos de ces albums seront sauvegardées." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur Fotos aus diesen Alben werden gesichert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Only photos from these albums will be backed up."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo se respaldarán las fotos de estos álbumes."
          }
        },
