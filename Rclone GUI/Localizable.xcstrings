    "Tu peux maintenant parcourir tes remotes, transférer des fichiers et lire tes médias depuis Fichiers." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst jetzt deine Remotes durchsuchen, Dateien übertragen und deine Medien über „Dateien“ wiedergeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can now browse your remotes, transfer files and play your media from Files."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahora puedes explorar tus remotos, transferir archivos y reproducir tu contenido desde Archivos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu peux maintenant parcourir tes remotes, transférer des fichiers et lire tes médias depuis Fichiers."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ora puoi esplorare i tuoi remoti, trasferire file e riprodurre i tuoi contenuti da File."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これで、リモートを閲覧し、ファイルを転送し、「ファイル」からメディアを再生できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이제 “파일”에서 리모트를 탐색하고, 파일을 전송하고, 미디어를 재생할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt nu door je remotes bladeren, bestanden overdragen en je media afspelen vanuit Bestanden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz teraz przeglądać swoje remote, przesyłać pliki i odtwarzać multimedia z Plików."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agora você pode navegar pelos seus remotos, transferir arquivos e reproduzir suas mídias em Arquivos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Теперь вы можете просматривать ваши remote, передавать файлы и воспроизводить медиа из «Файлов»."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "现在，您可以从“文件”浏览您的远程、传输文件并播放您的媒体。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在，您可以從“檔案”瀏覽您的遠端、傳輸檔案並播放您的媒體。"
          }
        }
      }
    },
