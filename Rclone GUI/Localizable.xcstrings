    "Au-delà de cette durée sans utilisation, l'app re-demande la biométrie. Phase E2 ajoutera le wipe automatique du cache.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After this period of inactivity, the app asks for biometrics again. Phase E2 will add automatic cache wiping."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Au-delà de cette durée sans utilisation, l'app re-demande la biométrie. Phase E2 ajoutera le wipe automatique du cache."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras este periodo de inactividad, la app vuelve a pedir la biometría. La fase E2 añadirá el borrado automático de la caché."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dopo questo periodo di inattività, l'app richiede di nuovo la biometria. La fase E2 aggiungerà la cancellazione automatica della cache."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nach diesem Zeitraum der Inaktivität fragt die App erneut nach Biometrie. Phase E2 fügt das automatische Löschen des Caches hinzu."
          }
        }
      }
    },
