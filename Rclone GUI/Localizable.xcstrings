        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo interativo é compatível com 100% dos backends do rclone, incluindo os que não estão listados no catálogo gráfico."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Интерактивный режим совместим со 100% бэкендов rclone, включая те, что не указаны в графическом каталоге."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インタラクティブモードは、グラフィカルカタログに記載されていないものを含め、rclone バックエンドの 100% に対応しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대화형 모드는 그래픽 카탈로그에 나열되지 않은 것을 포함하여 rclone 백엔드의 100%와 호환됩니다."
          }
        }
      }
    },
    "Le panel affiche un OAuth token immédiatement.": {
