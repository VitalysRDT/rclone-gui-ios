# Fastlane configuration for Rclone GUI
#
# Setup (one-time):
#   1. brew install fastlane
#   2. Create an App Store Connect API key:
#      App Store Connect → Users and Access → Keys → "+"
#      Role: "App Manager" or higher. Download the .p8 file once.
#   3. Place the .p8 at fastlane/.appstore-key.p8 (gitignored)
#   4. Export the key metadata:
#        export ASC_KEY_ID="ABC123DEF4"
#        export ASC_ISSUER_ID="aaaa-bbbb-cccc-dddd-eeee"
#
# Daily use:
#   bundle exec fastlane upload_metadata        # push metadata only
#   bundle exec fastlane upload_screenshots     # push screenshots only
#   bundle exec fastlane submit                 # build + upload + submit for review

default_platform(:ios)

ASC_KEY_PATH = File.expand_path("../fastlane/.appstore-key.p8", __dir__)

def asc_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ASC_KEY_PATH,
    in_house: false
  )
end

platform :ios do
  desc "Push localized metadata (no binary, no screenshots) to App Store Connect"
  lane :upload_metadata do
    deliver(
      api_key: asc_key,
      app_version: "1.9.1",    # cible explicitement la version 1.9.1
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,           # don't prompt for interactive confirmation
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Push screenshots only"
  lane :upload_screenshots do
    deliver(
      api_key: asc_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Resubmit existing binary for review after metadata fixes (no rebuild)"
  lane :resubmit do
    deliver(
      api_key: asc_key,
      build_number: "136",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      reject_if_possible: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
        export_compliance_contains_third_party_cryptography: true,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_available_on_french_store: true,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Create the iOS version, attach already-uploaded build, push metadata, submit for review"
  lane :ship do
    deliver(
      api_key: asc_key,
      app_version: "2.0",
      build_number: "141",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: true,
      reject_if_possible: true,   # annule la revue 2.0 en cours pour attacher 141
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
        export_compliance_contains_third_party_cryptography: true,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_available_on_french_store: true,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Full submission: archive + upload + send for review"
  lane :submit do
    build_app(
      scheme: "Rclone GUI",
      # Le projet liste désormais iphoneos/macosx/xros : sans destination
      # explicite, gym auto-détecte visionOS. On force iOS.
      destination: "generic/platform=iOS",
      export_method: "app-store",
      configuration: "Release",
      clean: true,
      output_directory: "build/",
      include_symbols: true,
      include_bitcode: false,
      xcargs: "-allowProvisioningUpdates"
    )
    deliver(
      api_key: asc_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
        export_compliance_contains_third_party_cryptography: true,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_available_on_french_store: true,
        content_rights_contains_third_party_content: false
      }
    )
  end
end

platform :mac do
  desc "Archive the macOS Release build (App Store) and upload to App Store Connect"
  lane :upload_mac do
    # Charge la clé API DANS le lane context AVANT build_app pour que gym passe
    # -authenticationKey* à xcodebuild archive ET export → -allowProvisioningUpdates
    # peut créer les profils Mac App Store (app + extension) au premier build Mac.
    key = asc_key
    build_app(
      scheme: "Rclone GUI",
      destination: "generic/platform=macOS",
      export_method: "app-store",
      configuration: "Release",
      clean: false,
      output_directory: "build/mac",
      # RcloneKit n'a qu'une tranche macos/arm64 (cible Apple Silicon) ;
      # l'archive Release par défaut tente arm64+x86_64 → échec de link de
      # l'extension. On force arm64 uniquement.
      xcargs: "-allowProvisioningUpdates ARCHS=arm64"
    )
    deliver(
      api_key: key,
      platform: "osx",
      pkg: lane_context[SharedValues::PKG_OUTPUT_PATH],
      skip_screenshots: true,
      skip_metadata: true,
      skip_binary_upload: false,
      submit_for_review: false,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Push localized metadata to the macOS App Store version"
  lane :upload_mac_metadata do
    deliver(
      api_key: asc_key,
      platform: "osx",
      app_version: "1.9.1",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Push macOS screenshots only (en-US + fr-FR)"
  lane :upload_mac_screenshots do
    deliver(
      api_key: asc_key,
      platform: "osx",
      screenshots_path: "./fastlane/screenshots-mac",
      app_version: "1.9.1",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false
    )
  end

  desc "Submit the macOS version for review (build already uploaded)"
  lane :submit_mac do
    deliver(
      api_key: asc_key,
      platform: "osx",
      app_version: "2.0",
      build_number: "141",
      submit_for_review: true,
      reject_if_possible: true,   # annule la revue macOS 2.0 en cours pour attacher 141
      automatic_release: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
        export_compliance_contains_third_party_cryptography: true,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_available_on_french_store: true,
        content_rights_contains_third_party_content: false
      }
    )
  end
end
